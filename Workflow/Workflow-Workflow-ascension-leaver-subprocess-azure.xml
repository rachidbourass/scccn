<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE Workflow PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Workflow explicitTransitions="true" monitored="true" name="Workflow-Ascension-Leaver-Subprocess-Azure" type="Subprocess">
  <Variable input="true" name="identityName">
    <Description>Passed in from Leaver Wrapper</Description>
  </Variable>
  <Variable input="true" name="azureUpn">
    <Description>UPN attribute from Azure link; passed in from Leaver Wrapper</Description>
  </Variable>
  <Variable initializer="script:return getAzureAuthToken();" name="azureToken">
    <Description>Placeholder variable; populated during workflow</Description>
  </Variable>
  <Variable initializer="script:false" name="skipStep">
    <Description>For Step Conditions (e.g. When skipStep)</Description>
  </Variable>
  <Variable input="true" name="project">
    <Description>Passed in from Leaver Wrapper</Description>
  </Variable>
  <Description>Handles Leaver Operations for the Duo Application.</Description>
  <RuleLibraries>
    <Reference class="sailpoint.object.Rule" name="Ascension-RuleLibrary-Azure"/>
  </RuleLibraries>
  <Step icon="Start" name="Start" posX="183" posY="25">
    <Transition to="Disable Azure Account"/>
  </Step>
  <Step action="script:return getAzureAuthToken();" icon="Analysis" name="Get Auth Token" posX="223" posY="230" resultVariable="azureToken"/>
  <Step action="script:disableAzureAccount(azureToken, azureUpn);" icon="Provision" name="Disable Azure Account" posX="299" posY="21">
    <Transition to="Revoke Azure Sessions"/>
  </Step>
  <Step action="script:revokeAzureSession(azureToken, azureUpn);" icon="Provision" name="Revoke Azure Sessions" posX="393" posY="21">
    <Transition to="Stop"/>
  </Step>
  <Step icon="Stop" name="Stop" posX="803" posY="21"/>
  <Step action="rule:Rule-Ascension-FinalizeWorkflow" catches="complete" icon="Catches" name="Finalize" posX="732" posY="128">
    <Transition to="Stop"/>
  </Step>
</Workflow>