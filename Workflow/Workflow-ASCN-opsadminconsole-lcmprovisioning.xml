<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE Workflow PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Workflow handler="sailpoint.api.StandardWorkflowHandler" name="ASCN-Workflow-Opsadminconsole">
  <Variable name="identityName"/>
  <Variable name="selectedWorkItems"/>
  <Variable name="selectedWorkItemNames"/>
  <Variable input="true" name="httpSession" transient="true">
    <Description>httpSession</Description>
  </Variable>
  <Variable name="employee"/>
  <Variable name="comments"/>
  <Variable name="manager"/>
  <Variable name="sendMail"/>
  <Variable name="actionType"/>
  <Variable name="targetOwner"/>
  <Variable name="taskName"/>
  <Variable name="idAttribute"/>
  <Variable name="op"/>
  <Variable name="oldValue"/>
  <Variable name="newValueExpDate"/>
  <Variable name="newValue"/>
  <Variable initializer="Ops Override" name="flow"/>
  <RuleLibraries>
    <Reference class="sailpoint.object.Rule" name="ASCN-Rule-Opsadminconsole-Rulelibrary"/>
    <Reference class="sailpoint.object.Rule" name="ASCN-RuleLibrary-Common"/>
  </RuleLibraries>
  <Step icon="Start" name="Start" posX="25" posY="50">
    <Transition to="Launch Form"/>
  </Step>
  <Step icon="Approval" name="Launch Form" posX="50" posY="50">
    <Approval name="Launch Form" owner="ref:launcher" return="employee,actionType,appname,entitlements,sendMail,manager,comments,origRequestId,taskName,processLifeCycle,appRoles,idAttribute,op,operation,oldValue,newValueExpDate,newValue,singleAggAppName,userForTask">
      <Arg name="workItemForm" value="ASCN-Form-Opsadminconsole"/>
      <Arg name="workItemDescription" value="ASCN Ops Admin Console"/>
    </Approval>
    <Transition to="Stop" when="!script:approved"/>
    <Transition to="Enable Identity Links" when="script:(&quot;Enable Identity Links&quot;.equals(actionType))"/>
    <Transition to="Disable Identity Links" when="script:(&quot;Disable Identity Links&quot;.equals(actionType))"/>
    <Transition to="Request Entitlements" when="script:(&quot;Request Entitlements&quot;.equals(actionType))"/>
    <Transition to="Launch Joiner Workflow" when="script:(&quot;Launch Joiner Workflow&quot;.equals(actionType))"/>
    <Transition to="Run Task" when="script:(&quot;Select Task&quot;.equals(operation))"/>
    <Transition to="Remove Entitlements" when="script:(&quot;Remove Entitlements&quot;.equals(actionType))"/>
    <Transition to="Update Manager" when="script:(&quot;Update Manager&quot;.equals(actionType))"/>
    <Transition to="Update Attribute" when="script:(&quot;Update Attribute&quot;.equals(actionType))"/>
    <Transition to="SingleAccAgg" when="script:(&quot;Single Account Aggregation&quot;.equals(actionType))"/>
    <Transition to="Relaunch Termination" when="script:(&quot;Relaunch Termination&quot;.equals(actionType))"/>
    <Transition to="Stop"/>
  </Step>
  <Step background="true" icon="task" name="Enable Identity Links" posX="75" posY="50">
    <Arg name="flow" value="Ops Enable Identity Links"/>
    <Script>
      <Source><![CDATA[
        import sailpoint.object.ProvisioningPlan;
        ProvisioningPlan plan = enableAllLinks(employee);  
        launchWorkflow(employee,plan,comments,flow);
        logAuditEvent("Enable Identity Links",null,null,comments,employee);
      ]]></Source>
    </Script>
    <Transition to="Stop"/>
  </Step>
  <Step background="true" icon="task" name="Disable Identity Links" posX="100" posY="50">
    <Arg name="flow" value="Ops Disable Identity Links"/>
    <Script>
      <Source><![CDATA[
        import sailpoint.object.ProvisioningPlan;
        ProvisioningPlan plan = disableAllLinks(employee);     
        launchWorkflow(employee,plan,comments,flow);
        logAuditEvent("Disable Identity Links",null,null,comments,employee);
      ]]></Source>
    </Script>
    <Transition to="Stop"/>
  </Step>
  <Step background="true" icon="task" name="Run Task" posX="125" posY="50">
    <Script>
      <Source><![CDATA[        
        opsRunTask(taskName,userForTask);
        String usersList = Util.listToCsv(userForTask);
        logAuditEvent("Run Task","taskName",taskName,comments,usersList);
      ]]></Source>
    </Script>
    <Transition to="Stop"/>
  </Step>
  <Step background="true" icon="task" name="Remove Entitlements" posX="125" posY="50">
    <Arg name="flow" value="Ops Remove Entitlment"/>
    <Script>
      <Source><![CDATA[
        import sailpoint.object.ProvisioningPlan;    
        ProvisioningPlan plan = getEntitlementPlan(employee,appname,entitlements,"Remove");       
        launchWorkflow(employee,plan,comments,flow);
        String entitlementsList = Util.listToCsv(entitlements);
        logAuditEvent("Remove Entitlements","entitlements",entitlementsList,comments,employee);
        return;
      ]]></Source>
    </Script>
    <Transition to="Stop"/>
  </Step>
  <Step background="true" icon="task" name="Request Entitlements" posX="150" posY="50">
    <Arg name="flow" value="Ops Request Access"/>
    <Arg name="securityOfficerName" value="Ops Approvers"/>
    <Arg name="approvalScheme" value="securityOfficer"/>
    <Script>
      <Source><![CDATA[
        import sailpoint.object.ProvisioningPlan;
        ProvisioningPlan plan = getEntitlementPlan(employee,appname,entitlements,"Add");
        launchWorkflow(employee,plan,comments,flow);
        String entitlementsList = Util.listToCsv(entitlements);
        logAuditEvent("Remove Entitlements","entitlements",entitlementsList,comments,employee);
      ]]></Source>
    </Script>
    <Transition to="Stop"/>
  </Step>
  <Step background="true" icon="task" name="Launch Joiner Workflow" posX="175" posY="50">
    <Script>
      <Source><![CDATA[ 
        cleanUpIdentity(employee);
        launchWorkflow(employee,"Ascension-Workflow-Persona-Joiner-Process",launcher,false,comments);
        logAuditEvent("Launch Joiner Workflow",null,null,comments,employee);
      ]]></Source>
    </Script>
    <Transition to="Stop"/>
  </Step>
  <Step background="true" icon="task" name="Relaunch Termination" posX="175" posY="50">
    <Script>
      <Source><![CDATA[
        launchLeaver(employee,"Ascension-Workflow-Immediate-Termination",launcher);
        logAuditEvent("Relaunch Termination",null,null,comments,employee);
      ]]></Source>
    </Script>
    <Transition to="Stop"/>
  </Step>
  <Step background="true" icon="task" name="Update Manager" posX="75" posY="50">
    <Arg name="flow" value="Ops Update Manager"/>
    <Script>
      <Source><![CDATA[      
        ProvisioningPlan plan = getIdentityCubePlan(employee,"manager",manager);
        launchWorkflow(employee,plan,comments,flow);
        logAuditEvent("Update Manager","manager",manager,comments,employee);
        return;
      ]]></Source>
    </Script>
    <Transition to="Stop"/>
  </Step>
  <Step background="true" icon="task" name="Update Attribute" posX="75" posY="50">
    <Arg name="flow" value="Ops Update Attribute"/>
    <Arg name="approvalScheme" value="none"/>
    <Script>
      <Source><![CDATA[
        ProvisioningPlan plan = null;
        String opsconCustomObjectName = "ASCN-Custom-Opsadminconsole";
        String updateAttrKey ="updateAttribute";
        if(op!=null){
        if(op.equals("Update")){
        if(newValueExpDate != null){
        plan  = getIdentityCubePlan(employee,"ctrexpDt",newValueExpDate);
        }
        else{
        String idAtrr = GeneralUtils.loadCustomMap("updateAttribute", opsconCustomObjectName).get(idAttribute);
        plan = getIdentityCubePlan(employee,idAtrr,newValue);

        }
        }
        else{
        if(idAttribute.equals("Contractor Expiration Date")){
        plan = getIdentityCubePlan(employee,"ctrexpDt",null);
        }
        else{
        String idAtrr = GeneralUtils.loadCustomMap("updateAttribute", opsconCustomObjectName).get(idAttribute);
        plan = getIdentityCubePlan(employee,idAtrr,null);
        }
        }

        launchWorkflow(employee,plan,comments,flow);
        if(newValueExpDate != null){
        logAuditEvent("Update Attribute",idAttribute,newValueExpDate,comments,employee);
        } else {
        logAuditEvent("Update Attribute",idAttribute,newValue,comments,employee);
        } 
        return;
        }
      ]]></Source>
    </Script>
    <Transition to="Stop"/>
  </Step>
  <Step background="true" icon="task" name="SingleAccAgg" posX="125" posY="50">
    <Script>
      <Source><![CDATA[
        singleAccountAggregation(singleAggAppName,employee);
        logAuditEvent("SingleAccAgg","singleAggAppName",singleAggAppName,comments,employee);
        return;
      ]]></Source>
    </Script>
    <Transition to="Stop"/>
  </Step>
  <Step icon="Stop" name="Stop" posX="200" posY="50"/>
</Workflow>