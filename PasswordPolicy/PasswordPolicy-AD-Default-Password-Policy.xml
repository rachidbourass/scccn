<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE PasswordPolicy PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<PasswordPolicy description="" name="AD Default Password Policy">
  <PasswordConstraints>
    <Map>
      <entry key="checkPasswordsAgainstAccountAttributes">
        <value>
          <Boolean></Boolean>
        </value>
      </entry>
      <entry key="checkPasswordsAgainstDictionary">
        <value>
          <Boolean></Boolean>
        </value>
      </entry>
      <entry key="checkPasswordsAgainstIdentityAttributes">
        <value>
          <Boolean></Boolean>
        </value>
      </entry>
      <entry key="passwordHistory"/>
      <entry key="passwordMaxLength"/>
      <entry key="passwordMinAlpha" value="4"/>
      <entry key="passwordMinLength" value="12"/>
      <entry key="passwordMinLower" value="3"/>
      <entry key="passwordMinNumeric" value="2"/>
      <entry key="passwordMinSpecial" value="0"/>
      <entry key="passwordMinUpper" value="3"/>
    </Map>
  </PasswordConstraints>
</PasswordPolicy>
