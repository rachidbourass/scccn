<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE DynamicScope PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<DynamicScope name="ASCN-Manager">
  <ApplicationRemoveControl>
    <Reference class="sailpoint.object.Rule" name="Ascension-Rule-RequestObjectSelector-Applications-Standard"/>
  </ApplicationRemoveControl>
  <ApplicationRequestControl>
    <Reference class="sailpoint.object.Rule" name="Ascension-Rule-RequestObjectSelector-Applications-Standard"/>
  </ApplicationRequestControl>
  <PopulationRequestAuthority allowAll="true"/>
  <Selector>
    <IdentitySelector>
      <MatchExpression and="true">
        <MatchTerm name="assignedRoles" negative="true" type="IdentityAttribute" value="iamProvisionerRights"/>
        <MatchTerm container="true">
          <MatchTerm name="managerStatus" type="IdentityAttribute" value="true"/>
          <MatchTerm name="isContractorManager" type="IdentityAttribute" value="true"/>
          <MatchTerm name="workgroups" type="IdentityAttribute" value="Trusted Requesters Provisioning"/>
          <MatchTerm name="workgroups" type="IdentityAttribute" value="Trusted Requesters TNNAS"/>
          <MatchTerm name="workgroups" type="IdentityAttribute" value="Trusted Requesters ININD"/>
          <MatchTerm name="workgroups" type="IdentityAttribute" value="Trusted Requesters AHSCN"/>
        </MatchTerm>
      </MatchExpression>
    </IdentitySelector>
  </Selector>
</DynamicScope>
