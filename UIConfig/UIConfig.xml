<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE sailpoint PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<sailpoint>
<ImportAction name='merge'>
<UIConfig name="UIConfig">
  <Attributes>
    <Map>
       <!-- show these fields on identity detail screen -->
	   <entry key="identityViewAttributes" value="name,firstname,lastname,email,manager,samAccountName,type,ctrexpDt,orgUnitPath,inactive,gsuiteStatus,childPersonas,childPersonaNames,parentPersonaName,parentPersonaSID,personaType,internalId,domainAccounts"/>
       <!-- these fields on cube used for search -->
	   <entry key="identitySearchAttributes" value="displayName,name,firstname,lastname,email,employeeId,samAccountName,domainAccounts"/>
       <!-- add identity attributes to be displayed on the user card for the Manage User Access-->
	   <entry key="uiRequestAccessIdentityCard">
        <value>
          <List>
             <ColumnConfig dataIndex="domainAccounts" groupProperty="domainAccounts" headerKey="Domain(s) Accounts" property="domainAccounts" sortProperty="domainAccounts" stateId="domainAccounts"/>
          </List>
        </value>
      </entry>
    </Map>
  </Attributes> 
</UIConfig>
</ImportAction>
</sailpoint>