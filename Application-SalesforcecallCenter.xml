  <ProvisioningConfig>
    <PlanInitializerScript>
      <Source><![CDATA[
		import sailpoint.object.ProvisioningPlan;
		import sailpoint.object.ProvisioningPlan.AccountRequest;
		import sailpoint.object.ProvisioningPlan.AccountRequest.Operation;
		import sailpoint.object.ProvisioningPlan.AttributeRequest;
		
		String noAccessProfileId = "00e3F000000WFi7";

		if(plan!=null){

			String operation = "Add";
			String allAttOperations = "";
			List<AttributeRequest> removeAttReqList = new ArrayList();
			List<AccountRequest> accReqs = plan.getAccountRequests();
			if ((accReqs != null) && !accReqs.isEmpty()) {
				// Iterate through AccountRequests
				for (AccountRequest accReq : accReqs) {
					operation = "Add";
					allAttOperations = "";
					List<AttributeRequest> attrReqs = accReq.getAttributeRequests();
					if ((attrReqs != null) && !attrReqs.isEmpty()) {
						// Iterate through AttributeRequests and find dummy entitlement
						for (AttributeRequest attrReq : attrReqs) {
							if (attrReq.getOperation() != null && attrReq.getOperation().toString().equalsIgnoreCase("Add")) {
								operation = "Add";
								allAttOperations = allAttOperations+operation;
							} else if(attrReq.getOperation() != null && attrReq.getOperation().toString().equalsIgnoreCase("Remove")){
								operation = "Remove";
								allAttOperations = allAttOperations+operation;
								if( "RoleTest".equalsIgnoreCase(attrReq.getName()) || "ProfileId".equalsIgnoreCase(attrReq.getName())){
									removeAttReqList.add(attrReq);
								}
							}
						}
						if(!removeAttReqList.isEmpty()){
							for(AttributeRequest attR : removeAttReqList){
								accReq.remove(attR);
							}
						}
						removeAttReqList.clear();
					}
				
					if ((!allAttOperations.contains("Add") && allAttOperations.contains("Remove")) ) {
						// Add isActive AttributeRequest to AccountRequest
						accReq.add(new AttributeRequest("ProfileId",ProvisioningPlan.Operation.Add, noAccessProfileId));
					} else if ((allAttOperations.contains("Add") && !allAttOperations.contains("Remove"))  && 
					!(accReq.getOperation()!=null && "Create".equalsIgnoreCase((accReq.getOperation().name()))) ) {
						// Add isActive AttributeRequest to AccountRequest
						accReq.add(new AttributeRequest("IsActive",ProvisioningPlan.Operation.Set,true));
					}
				}
			}
		}
    
      ]]></Source>
    </PlanInitializerScript>
