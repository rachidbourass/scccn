<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE EmailTemplate PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<EmailTemplate name="Ascension-EmailTemplate-Rehire-Report-Notification">
  <Body>
    &lt;!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
    &lt;html xmlns="http://www.w3.org/1999/xhtml">

    &lt;head>
    &lt;meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    &lt;title>Rehire Report Email &lt;/title>

    &lt;/head>

    &lt;body bgcolor="#F2F2F2" style="">
    &lt;h2>Rehire Report &lt;/h2>
    &lt;p>Please verify the workers in the attached file are fully processed. &lt;/p>
    &lt;p>If you have any questions, please reach out to the Identity Governance Team. &lt;/p>
    &lt;p>Thank You &lt;/p>

   </Body>
  <Signature>
    <Inputs>
      <Argument name="map" type="LinkedHashMap">
        <Description>The Workflow object being executed.</Description>
      </Argument>
      <Argument name="startDate" type="string">
        <Description>StartDate</Description>
      </Argument>
      <Argument name="endDate" type="string">
        <Description>EndDate</Description>
      </Argument>
      <Argument name="currentDate" type="string">
        <Description>CurrentDate</Description>
      </Argument>
    </Inputs>
  </Signature>
  <Subject>SailPoint - Rehire Report - $currentDate </Subject>
</EmailTemplate>
