<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE Form PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Form name="Ascension-Form-Rehire-Market-Transfer" type="Workflow">
  <Attributes>
    <Map>
      <entry key="pageTitle" value="Rehire - Market Transfer for user : $(identityDisplayName) [$(identityName)]"/>
      <entry key="subtitle" value="Please complete all required processing for this user and click on End Workflow to complete the workitem."/>
      <entry key="title" value="Rehire - Market Transfer"/>
    </Map>
  </Attributes>
  <Section label="Rehire details" name="rehireDetails" type="datatable">
    <Field displayName="Case Type" name="rehireTypeDetails"/>
  </Section>
  <Section columns="2" label="Event details" name="eventDetails" type="datatable">
    <Field columnSpan="1" displayName="Identity Name" name="identityName"/>
    <Field columnSpan="1" displayName="DisplayName" name="identityDisplayName"/>
    <Field columnSpan="1" displayName="Network Logon ID" name="networkID">
      <Script>
        <Source><![CDATA[
          import sailpoint.tools.Util;
          if(Util.isNullOrEmpty(networkID)){
          return "Not Available";
          }
        ]]></Source>
      </Script>
    </Field>
    <Field columnSpan="1" displayName="Manager" name="manager">
      <Script>
        <Source><![CDATA[
          import sailpoint.object.Identity;
          import sailpoint.tools.Util;
          String managerName = ""; 

          if(Util.isNotNullOrEmpty(identityName)){
          Identity idn = context.getObjectByName(Identity.class, identityName);
          if (idn != null){
          Identity mgrIdentity = idn.getManager();
          if(null != mgrIdentity){
          managerName = mgrIdentity.getName() +" - "+mgrIdentity.getDisplayName();
          }else{
          managerName = "Not Available";
          }
          }
          }
          return managerName;
        ]]></Source>
      </Script>
    </Field>
    <Field columnSpan="2" displayName="EffectiveDate" name="effectiveDate">
      <Script>
        <Source><![CDATA[
          import sailpoint.object.Identity;
          import sailpoint.tools.Util;
          String effectiveDate = "";
          if (Util.isNotNullOrEmpty(identityName)) 
          {
          Identity idn = context.getObjectByName(Identity.class, identityName);
          effectiveDate = identity.getAttribute("effectiveDate");
          }
          if(Util.isNullOrEmpty(effectiveDate)){
          effectiveDate = "Not Available";
          }
          return effectiveDate;
        ]]></Source>
      </Script>
    </Field>
    <Field columnSpan="1" displayName="Old SETID_LOCATION" name="oldSetIDLocation">
      <Script>
        <Source><![CDATA[
          import sailpoint.tools.Util;
          if(Util.isNullOrEmpty(oldSetIDLocation)){
          return "Not Available";
          }
        ]]></Source>
      </Script>
    </Field>
    <Field columnSpan="1" displayName="New SETID_LOCATION" name="newSetIDLocation">
      <Script>
        <Source><![CDATA[
          import sailpoint.tools.Util;
          if(Util.isNullOrEmpty(newSetIDLocation)){
          return "Not Available";
          }
        ]]></Source>
      </Script>
    </Field>
  </Section>
  <Section columns="2" label="Type Change Details" name="typeChangeDetails" type="datatable">
    <Field columnSpan="1" displayName="Old Type" name="oldTypeValue">
      <Attributes>
        <Map>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[
                  import sailpoint.tools.Util;
                  if(Util.isNullOrEmpty(oldTypeValue)){
                  return true;
                  }
                  ]]></Source>
              </Script>
            </value>
          </entry>
        </Map>
      </Attributes>
    </Field>
    <Field columnSpan="1" displayName="New Type" name="newTypeValue">
      <Attributes>
        <Map>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[
                  import sailpoint.tools.Util;
                  if(Util.isNullOrEmpty(newTypeValue)){
                  return true;
                  }
                  ]]></Source>
              </Script>
            </value>
          </entry>
        </Map>
      </Attributes>
    </Field>
    <Field columnSpan="2" displayName="Note" name="userTypeWorkItemDesc">
      <Attributes>
        <Map>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[
                  import sailpoint.tools.Util;
                  if(Util.isNullOrEmpty(userTypeWorkItemDesc)){
                  return true;
                  }
                ]]></Source>
              </Script>
            </value>
          </entry>
        </Map>
      </Attributes>
    </Field>
  </Section>
  <Section columns="2" label="Employee Class Change Details" name="emplClassChangeDetails" type="datatable">
    <Field columnSpan="1" displayName="OldEmplClassValue" name="oldEmplClassValue">
      <Attributes>
        <Map>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[
                  import sailpoint.tools.Util;
                  if(Util.isNullOrEmpty(oldEmplClassValue)){
                  return true;
                  }
                  ]]></Source>
              </Script>
            </value>
          </entry>
        </Map>
      </Attributes>
    </Field>
    <Field columnSpan="1" displayName="NewEmplClassValue" name="newEmplClassValue">
      <Attributes>
        <Map>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[
                  import sailpoint.tools.Util;
                  if(Util.isNullOrEmpty(newEmplClassValue)){
                  return true;
                  }
                  ]]></Source>
              </Script>
            </value>
          </entry>
        </Map>
      </Attributes>
    </Field>
    <Field columnSpan="2" displayName="Note" name="emplClassWorkItemDesc">
      <Attributes>
        <Map>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[
                  import sailpoint.tools.Util;
                  if(Util.isNullOrEmpty(emplClassWorkItemDesc)){
                  return true;
                  }
                  ]]></Source>
              </Script>
            </value>
          </entry>
        </Map>
      </Attributes>
    </Field>
  </Section>
  <Section label="Link Display Names" name="linkNames" type="datatable">
    <Field displayName="Link Display Names" name="linkDisplayNames" type="string">
      <Attributes>
        <Map>
          <entry key="hidden" value="true"/>
        </Map>
      </Attributes>
      <Script>
        <Includes>
          <Reference class="sailpoint.object.Rule" name="Ascension-RuleLibrary-Rehire"/>
          <Reference class="sailpoint.object.Rule" name="ASCN-RuleLibrary-Common"/>
        </Includes>
        <Source><![CDATA[
          Map linkDisplayNames = getLinkDisplayNames(identityName);
          return linkDisplayNames;
        ]]></Source>
      </Script>
    </Field>
    <Field dependencies="linkDisplayNames" displayName="DB-PeopleSoft-Primary" name="peopleSoftAccount">
      <Attributes>
        <Map>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[
                  import sailpoint.tools.Util;
                  if(Util.isNullOrEmpty(peopleSoftAccount)){
                  return true;
                  }
                  ]]></Source>
              </Script>
            </value>
          </entry>
        </Map>
      </Attributes>
      <Script>
        <Source><![CDATA[return linkDisplayNames.get("PeopleSoft account");]]></Source>
      </Script>
    </Field>
    <Field dependencies="linkDisplayNames" displayName="AD" name="adAccountNames">
      <Attributes>
        <Map>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[
                  import sailpoint.tools.Util;
                  if(Util.isNullOrEmpty(adAccountNames)){
                  return true;
                  }
                  ]]></Source>
              </Script>
            </value>
          </entry>
        </Map>
      </Attributes>
      <Script>
        <Source><![CDATA[return linkDisplayNames.get("AD accounts");]]></Source>
      </Script>
    </Field>
    <Field dependencies="linkDisplayNames" displayName="ServiceNow" name="serviceNowAccountNames">
      <Attributes>
        <Map>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[
                  import sailpoint.tools.Util;
                  if(Util.isNullOrEmpty(serviceNowAccountNames)){
                  return true;
                  }
                ]]></Source>
              </Script>
            </value>
          </entry>
        </Map>
      </Attributes>
      <Script>
        <Source><![CDATA[return linkDisplayNames.get("ServiceNow accounts");]]></Source>
      </Script>
    </Field>
    <Field dependencies="linkDisplayNames" displayName="GSuite" name="gsuiteAccount">
      <Attributes>
        <Map>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[
                  import sailpoint.tools.Util;
                  if(Util.isNullOrEmpty(gsuiteAccount)){
                  return true;
                  }
                  ]]></Source>
              </Script>
            </value>
          </entry>
        </Map>
      </Attributes>
      <Script>
        <Source><![CDATA[return linkDisplayNames.get("GSuite account");]]></Source>
      </Script>
    </Field>
  </Section>
  <Section name="commentSection">
    <Field dependencies="linkDisplayNames" displayName="Comments" helpKey="Please enter comments" name="comments" required="true" section="commentSection" type="string">
      <ValidationScript>
        <Includes>
          <Reference class="sailpoint.object.Rule" name="Ascension-RuleLibrary-Rehire"/>
          <Reference class="sailpoint.object.Rule" name="ASCN-RuleLibrary-Common"/>
        </Includes>
        <Source><![CDATA[
          import sailpoint.tools.Util;
          String message = null;
          String value = form.getField("comments").getValue(); 

          if(Util.isNotNullOrEmpty(value) && value.length() > 15 ){   
          message = "Enter only 15 characters";
          } else{
          if(!isPersonaMarketTransfer && ((oldTypeValue != null || newTypeValue != null) || (oldEmplClassValue != null || newEmplClassValue != null))){
          Map rehireAccountsMap = new HashMap();
          List potentialAccountsList = new ArrayList();

          boolean gSuiteAccountExists = false;

          boolean ifMatchingADAccountExists = false;

          rehireAccountsMap = findPotentialAccountsForRehire(identityName, "");

          if(rehireAccountsMap != null){
          potentialAccountsList = rehireAccountsMap.get("potentialAccountsList");
          }

          if(potentialAccountsList != null){
          for(String potentialAccount: potentialAccountsList){

          if(potentialAccount.startsWith("AD")){

          ifMatchingADAccountExists = true ; 

          }
          }
          }

          String gSuiteAccount = linkDisplayNames.get("GSuite account");
          
          if(null != gSuiteAccount){
          gSuiteAccountExists = true;
          }

          if(!ifMatchingADAccountExists && !gSuiteAccountExists){
          message = "Please create a valid AD and Gsuite account";
          } else if(!ifMatchingADAccountExists){
          message = "Please create a valid AD account";
          } else if(!gSuiteAccountExists){
          message = "Please create a valid Gsuite account";
          }

          }
          }
          return message;

        ]]></Source>
      </ValidationScript>
    </Field>
  </Section>
  <Button action="next" label="Resume Workflow"/>
  <Button action="cancel" label="Cancel"/>
</Form>