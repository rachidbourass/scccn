<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE Form PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Form name="Ascension-Form-ManagerAssignment" type="Workflow">
  <Button action="next" label="Submit"/>
  <Button action="cancel" label="Cancel" parameter="exitWorkflow" value="true"/>
  <Section>
    <Field displayName="Current Manager" dynamic="true" filterString="inactive != true &amp;&amp; managerStatus == true" helpKey="Select the Current Manager" name="currentManager" postBack="true" required="true" type="identity">
      <Attributes>
        <Map>
          <entry key="valueProperty" value="name"/>
        </Map>
      </Attributes>
      <ValidationScript>
        <Source><![CDATA[ 
          if(null == currentManager) { 
          return "Current Manager cannot be null";
          }            
        ]]></Source>
      </ValidationScript>
    </Field>
    <Field displayName="Proposed Manager" dynamic="true" helpKey="Select the Proposed Manager" name="proposedManager" postBack="true" required="true" type="identity">
      <Attributes>
        <Map>
          <entry key="filterString">
            <value>
              <Script>
                <Source><![CDATA[                       
                  if(currentManager != null) {
                  String filterString = "inactive != true && managerStatus==true && name != \""+currentManager+"\"";
                  field.setFilterString(filterString);        
                  }
                ]]></Source>
              </Script>
            </value>
          </entry>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[ 
                  if(currentManager == null)
                  return true;
                ]]></Source>
              </Script>
            </value>
          </entry>
          <entry key="valueProperty" value="name"/>
        </Map>
      </Attributes>
      <ValidationScript>
        <Source><![CDATA[ 
          if(null != currentManager && null != proposedManager && currentManager == proposedManager) { 
          return "Proposed Manager cannot be null or same as the current manager";
          }            
        ]]></Source>
      </ValidationScript>
    </Field>
    <Field displayName="Select All Reportees" dynamic="true" name="allReportees" postBack="true" type="boolean">
      <Attributes>
        <Map>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[ 
                  if((currentManager == null) || proposedManager == null)
                  return true;
                ]]></Source>
              </Script>
            </value>
          </entry>
        </Map>
      </Attributes>
      <ValidationScript>
        <Source><![CDATA[
          if(null == allReportees && null == selectedReportees) { 
          return "Please select reportees before submitting the form.";
          }
        ]]></Source>
      </ValidationScript>
    </Field>
    <Field displayName="Reportee(s) selected" dynamic="true" multi="true" name="selectedReportees" postBack="true" type="identity">
      <Attributes>
        <Map>
          <entry key="filterString">
            <value>
              <Script>
                <Source><![CDATA[                    
                  if(currentManager != null) {
                  String filterString = "inactive != true && manager.name == \""+currentManager+"\"";
                  field.setFilterString(filterString);        
                  }
                ]]></Source>
              </Script>
            </value>
          </entry>
          <entry key="hidden">
            <value>
              <Script>
                <Source><![CDATA[ 
                  if((currentManager == null) || proposedManager == null)
                  return true;
                ]]></Source>
              </Script>
            </value>
          </entry>
          <entry key="readOnly">
            <value>
              <Script>
                <Source><![CDATA[ 
                  if(null != allReportees && allReportees == true)
                  return true;
                ]]></Source>
              </Script>
            </value>
          </entry>
        </Map>
      </Attributes>
      <ValidationScript>
        <Source><![CDATA[
          if(null == allReportees && null == selectedReportees) { 
          return "Please select reportees before submitting the form";
          }
        ]]></Source>
      </ValidationScript>
    </Field>
  </Section>
</Form>