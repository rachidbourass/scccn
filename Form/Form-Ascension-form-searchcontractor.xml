<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE Form PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Form name="Ascension-Form-SearchContractor" type="Workflow">
  <Attributes>
    <Map>
      <entry key="pageTitle" value="Create Non-HR Contractor User"/>
    </Map>
  </Attributes>
  <Section columns="3" label="Contractor Information">
    <Field columnSpan="1" displayName="First Name" displayType="combobox" dynamic="true" name="firstname" postBack="true" required="true" type="String">
      <ValidationScript>
        <Includes>
          <Reference class="sailpoint.object.Rule" name="Ascension-Rule-ValidationLibrary"/>
        </Includes>
        <Source><![CDATA[
          import sailpoint.tools.Util;
          if(null != form.getField("firstname") && Util.isNotNullOrEmpty(form.getField("firstname").getValue()))
          {
          return validateAlphabets(form.getField("firstname").getValue());
          }
        ]]></Source>
      </ValidationScript>
    </Field>
    <Field columnSpan="1" displayName="Middle Name" name="middleName" postBack="true" type="String"/>
    <Field columnSpan="1" displayName="Last Name" displayType="combobox" name="lastname" postBack="true" required="true" type="String">
      <ValidationScript>
        <Includes>
          <Reference class="sailpoint.object.Rule" name="Ascension-Rule-ValidationLibrary"/>
        </Includes>
        <Source><![CDATA[
          import sailpoint.tools.Util;
          if(null != form.getField("lastname") && Util.isNotNullOrEmpty(form.getField("lastname").getValue()))
          {
          return validateAlphabets(form.getField("lastname").getValue());
          }
        ]]></Source>
      </ValidationScript>
    </Field>
    <Field columnSpan="1" displayName="Social Security Number(Last four digits)" name="ssn" postBack="true" required="true" type="String">
      <ValidationScript>
        <Includes>
          <Reference class="sailpoint.object.Rule" name="Ascension-Rule-ValidationLibrary"/>
        </Includes>
        <Source><![CDATA[
          import sailpoint.tools.Util;
          if(null != form.getField("ssn") && Util.isNotNullOrEmpty(form.getField("ssn").getValue()))
          {
          return validateSSN(form.getField("ssn").getValue());
          }
        ]]></Source>
      </ValidationScript>
    </Field>
    <Field columnSpan="1" displayName="DOB" helpKey="DOB format is MM/DD" name="dob" required="true" type="String">
      <ValidationScript>
        <Includes>
          <Reference class="sailpoint.object.Rule" name="Ascension-Rule-ValidationLibrary"/>
        </Includes>
        <Source><![CDATA[
          import sailpoint.tools.Util;
          if( null != form.getField("dob") && Util.isNotNullOrEmpty(form.getField("dob").getValue()))
          {
          return validateDOB(form.getField("dob").getValue());
          }
        ]]></Source>
      </ValidationScript>
    </Field>
    <Field columnSpan="1" displayName="Ministry" displayType="combobox" name="ministry" postBack="true" required="true" type="String">
      <AllowedValuesDefinition>
        <RuleRef>
          <Reference class="sailpoint.object.Rule" name="Ascension-Rule-Ministries"/>
        </RuleRef>
      </AllowedValuesDefinition>
      <Script>
        <Source><![CDATA[       
          import sailpoint.object.Identity;
          import sailpoint.tools.Util;
          import sailpoint.object.Form;

          String values = "";

          if(null != form.getField("ministry") && Util.isNotNullOrEmpty( form.getField("ministry").getValue())){
          values = form.getField("ministry").getValue();          
          }
          else if ( Util.isNotNullOrEmpty(identityModel.get("reenableContractorName")) && (null == identityModel.get("creationCheckbox") || !identityModel.get("creationCheckbox"))){
          Identity identity = context.getObjectByName(Identity.class, identityModel.get("reenableContractorName"));
          if (identity != null){
          values =  identity.getAttribute("ministry");
          //comment decache //context.decache(identity);
          }
          }

          return values;
        ]]></Source>
      </Script>
    </Field>
  </Section>
  <Button action="next" label="Next"/>
  <Button action="cancel" label="Cancel"/>
  <Button action="cancel" label="Return" readOnly="true"/>
</Form>