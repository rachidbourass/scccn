              List errors = null;
              String regex = "(?:\\+?(\\d{1,3}))?[-. (]*(\\d{3})[-. )]*(\\d{3})[-. ]*(\\d{4})";
              Pattern pattern = Pattern.compile(regex);
              if (phones != null) {
