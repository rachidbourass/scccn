      <Section name="Section 1">
        <Field displayName="Username &amp; Domain" name="Username &amp; Domain" required="true" type="string">
          <Script>
            <Source><![CDATA[import sailpoint.tools.Util;
              import sailpoint.object.Application;
              import sailpoint.object.Link;
              import sailpoint.object.Identity;
              import sailpoint.object.Custom;
              import sailpoint.api.SailPointContext;
              public String getUserName(Identity identity, SailPointContext context){
				String result = "";
				List<String> domains = null;
				try{
				List<Link> identityLinks = identity.getLinks();
				String userMinistry = identity.getStringAttribute("ministry");
				Custom custObj = context.getObjectByName(Custom.class,"Ascension-Custom-ContractorConfiguration");
		
				if(Util.isNotNullOrEmpty(userMinistry) && custObj!=null && custObj.get("Domain")!=null ){
					Map domainValues = (Map) custObj.get("Domain");
					domains = (List) domainValues.get(userMinistry);
					context.decache(custObj);
				}
				if (identityLinks != null) {
					for (Link appLink : identityLinks) {
						if(appLink != null && !appLink.isDisabled()){
							Application app = appLink.getApplication();
							if (Util.isNotNullOrEmpty(app.getType()) && app.getType().equalsIgnoreCase("Active Directory - Direct")) {
								result = (String) appLink.getAttribute("msDS-PrincipalName");
								
								if (Util.isNotNullOrEmpty(userMinistry) && domains !=null) {
									for (String singleDomain : domains) {
										if (appLink.getAttribute("msDS-PrincipalName") != null && singleDomain!=null && 
												appLink.getAttribute("msDS-PrincipalName").toString().toUpperCase().contains(singleDomain.toUpperCase())) {
											result = (String) appLink.getAttribute("msDS-PrincipalName");
											break;
										}
									}
								} 
							}
							// decache app
							context.decache(app);
						}
					}
				}
		      }
			  catch(GeneralException ge){
			    log.error("Exception in Tableau User name "+ge.getMessage());
		      }
		     return result;
	        }
           return getUserName(identity,context);]]></Source>
          </Script>
