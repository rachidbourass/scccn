<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE TaskDefinition PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<TaskDefinition executor="sailpoint.reporting.LiveReportExecutor" name="ASCN-Report-FailedJoinersReport" progressMode="Percentage" resultAction="Rename" subType="Identity and User Reports" template="true" type="LiveReport">
  <Attributes>
    <Map>
      <entry key="TaskDefinition.runLengthAverage" value="3"/>
      <entry key="TaskDefinition.runLengthTotal" value="26"/>
      <entry key="TaskDefinition.runs" value="7"/>
      <entry key="report">
        <value>
          <LiveReport title="Failed Joiners Report">
            <DataSource objectType="sailpoint.object.TaskResult" type="Filter">
              <QueryParameters>
                <Parameter defaultValue="Error" property="completionStatus"/>
                <Parameter property="name">
                  <QueryScript>
                    <Source><![CDATA[
                      import sailpoint.object.Filter;
				    Filter filter = Filter.like("name","Ascension-LifecycleEvent-Persona-Joiner ", Filter.MatchMode.START);
					queryOptions.addFilter(filter);
					return queryOptions;
				 ]]></Source>
                  </QueryScript>
                </Parameter>
                <Parameter operation="GT" property="launched">
                  <ValueScript>
                    <Source><![CDATA[
				   import java.util.Calendar;
				   import java.util.Date;
				   Date filterDate=new Date();

				   Calendar cal=Calendar.getInstance();
				   cal.setTime(filterDate);
           //int daysToDecrement=-30;
				   int daysToDecrement=-180;
				   cal.add(Calendar.DATE,daysToDecrement);
				   cal.set(Calendar.HOUR_OF_DAY,7);
				   cal.set(Calendar.MINUTE,0);
				    cal.set(Calendar.SECOND,0);

					filterDate=cal.getTime();

					return filterDate;
				 ]]></Source>
                  </ValueScript>
                </Parameter>
              </QueryParameters>
            </DataSource>
            <Columns>
              <ReportColumnConfig field="Task Name" header="Task Name" property="name" sortable="true" width="110"/>
              <ReportColumnConfig field="Error Message" header="Error" property="messages" sortable="true" width="110"/>
              <ReportColumnConfig field="Result" header="Result" property="completionStatus" sortable="true" width="110"/>
              <ReportColumnConfig field="launched" header="Launched" property="launched" sortable="true" width="110"/>
              <ReportColumnConfig field="completed" header="Completed" property="completed" sortable="true" width="110"/>
            </Columns>
          </LiveReport>
        </value>
      </entry>
    </Map>
  </Attributes>
  <Description>A detailed view of the failed joiners in the system.</Description>
  <RequiredRights>
    <Reference class="sailpoint.object.SPRight" name="FullAccessUncorrelatedIdentitiesReport"/>
  </RequiredRights>
  <Signature>
    <Inputs>
      <Argument name="resultScope" type="Scope">
        <Description>rept_input_result_scope</Description>
      </Argument>
      <Argument multi="true" name="emailIdentities" type="Identity">
        <Description>rept_input_email_recips</Description>
      </Argument>
    </Inputs>
  </Signature>
</TaskDefinition>