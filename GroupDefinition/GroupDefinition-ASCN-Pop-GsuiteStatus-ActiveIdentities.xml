<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE GroupDefinition PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<GroupDefinition indexed="true" name="Pop-GsuiteStatus-ActiveIdentities" private="true">
  <Description>Where Gsuite Status is not null</Description>
  <GroupFilter>
    <CompositeFilter operation="OR">
      <CompositeFilter operation="AND">
        <Filter ignoreCase="true" operation="EQ" property="company" value="NYAMS"/>
        <Filter operation="NOTNULL" property="gsuiteStatus"/>
        <Filter operation="EQ" property="inactive">
          <Value>
            <Boolean></Boolean>
          </Value>
        </Filter>
      </CompositeFilter>
      <CompositeFilter operation="AND">
        <Filter operation="NOTNULL" property="type"/>
        <Filter operation="EQ" property="inactive">
          <Value>
            <Boolean></Boolean>
          </Value>
        </Filter>
      </CompositeFilter>
      <CompositeFilter operation="AND">
        <Filter operation="ISNULL" property="type"/>
        <Filter operation="NOTNULL" property="gsuiteStatus"/>
        <Filter operation="EQ" property="inactive">
          <Value>
            <Boolean></Boolean>
          </Value>
        </Filter>
      </CompositeFilter>
    </CompositeFilter>
  </GroupFilter>
  <Index>
    <Reference class="sailpoint.object.GroupIndex" name="Pop-GsuiteStatus-ActiveIdentities"/>
  </Index>
  <Owner>
    <Reference class="sailpoint.object.Identity" name="No Manager Found"/>
  </Owner>
</GroupDefinition>
